#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if [[ ! -d "Poof.xcodeproj" ]]; then
  bin/generate-xcodeproj
fi

DERIVED_DATA_DIR="$ROOT_DIR/.build/xcode"
PRODUCTS_DIR="$DERIVED_DATA_DIR/Build/Products/Release"
APP_DIR="$PRODUCTS_DIR/Poof.app"

xcodebuild \
  -project "$ROOT_DIR/Poof.xcodeproj" \
  -scheme "Poof" \
  -configuration Release \
  -derivedDataPath "$DERIVED_DATA_DIR" \
  CODE_SIGNING_ALLOWED=NO \
  build

# Ad-hoc sign for local launching.
codesign --force --deep --sign - "$APP_DIR" >/dev/null 2>&1 || true

echo "Built app bundle: $APP_DIR"
open "$PRODUCTS_DIR"
