#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "fileutils"
require "time"

def usage!
  warn "Usage: bin/import-raycast-snippets <raycast-json-file> [output-dir]"
  exit 1
end

def toml_string(value)
  escaped = value.to_s
    .gsub("\\") { "\\\\" }
    .gsub("\"", "\\\"")
    .gsub("\n", "\\n")
    .gsub("\r", "\\r")
    .gsub("\t", "\\t")
  "\"#{escaped}\""
end

def category_for(keyword)
  return "bang_triggers" if keyword.start_with?("!")
  return "comma_triggers" if keyword.start_with?(",")
  return "at_triggers" if keyword.start_with?("@")

  "misc"
end

def transform_text(text)
  text
    .gsub(/\{cursor\}/, "{{cursor}}")
    .gsub(/\{date format=\"([^\"]+)\"\}/) { "{{date:#{$1}}}" }
    .gsub(/\{date\}/, "{{date}}")
    .gsub(/\{time\}/, "{{time}}")
    .gsub(/\{clipboard\}/, "{{clipboard}}")
end

input_file = ARGV[0] || usage!
output_dir = ARGV[1] || File.expand_path("~/Library/Application Support/Poof/snippets/raycast")

unless File.file?(input_file)
  warn "Input file not found: #{input_file}"
  exit 1
end

raw = JSON.parse(File.read(input_file))
unless raw.is_a?(Array)
  warn "Expected JSON array of snippets."
  exit 1
end

categorized = Hash.new { |hash, key| hash[key] = [] }

raw.each do |entry|
  keyword = entry.fetch("keyword", "").to_s.strip
  text = entry.fetch("text", "").to_s
  name = entry.fetch("name", keyword).to_s
  next if keyword.empty? || text.empty?

  categorized[category_for(keyword)] << {
    trigger: keyword,
    replace: transform_text(text),
    description: "Raycast: #{name}"
  }
end

FileUtils.mkdir_p(output_dir)
Dir.glob(File.join(output_dir, "raycast_*.toml")).each { |path| File.delete(path) }

timestamp = Time.now.utc.iso8601

categorized.keys.sort.each do |category|
  snippets = categorized.fetch(category).sort_by { |item| item[:trigger] }
  path = File.join(output_dir, "raycast_#{category}.toml")

  lines = []
  lines << "# Generated by bin/import-raycast-snippets at #{timestamp}"
  lines << "# Source: #{input_file}"
  lines << ""

  snippets.each do |snippet|
    lines << "[[snippets]]"
    lines << "trigger = #{toml_string(snippet[:trigger])}"
    lines << "replace = #{toml_string(snippet[:replace])}"
    lines << "description = #{toml_string(snippet[:description])}"
    lines << ""
  end

  File.write(path, lines.join("\n"))
end

puts "Imported #{raw.length} snippets into #{output_dir}"
categorized.keys.sort.each do |category|
  puts "  #{category}: #{categorized.fetch(category).length}"
end
