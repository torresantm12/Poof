#!/bin/bash
# Wrapper for xcodebuild that saves full logs while keeping stdout short.
set -eo pipefail

if [ $# -eq 0 ]; then
  echo "usage: $(basename "$0") <xcodebuild args...>" >&2
  exit 64
fi

mkdir -p ./.build/xcodebuild
mkdir -p ./.build/dd
timestamp=$(date +%Y-%m-%d-%H-%M-%S)
action=$1
safe_action=$(echo "$action" | tr -c '[:alnum:]-' '_')
log_file=$(mktemp "./.build/xcodebuild/xcodebuild-${safe_action}-${timestamp}.XXXXXX")

use_xcsift=0
if command -v xcsift >/dev/null 2>&1; then
  use_xcsift=1
fi

set +e
if [ "$use_xcsift" -eq 1 ]; then
  xcodebuild -derivedDataPath ./.build/dd "$@" 2>&1 \
    | tee "$log_file" \
    | xcsift --format toon --quiet --exit-on-failure
  pipe_status=("${PIPESTATUS[@]}")
  xcodebuild_exit=${pipe_status[0]}
  xcsift_exit=${pipe_status[2]}
  if [ "$xcodebuild_exit" -ne 0 ]; then
    exit_code=$xcodebuild_exit
  elif [ "$xcsift_exit" -ne 0 ]; then
    exit_code=$xcsift_exit
  else
    exit_code=0
  fi
else
  xcodebuild -derivedDataPath ./.build/dd "$@" &> "$log_file"
  exit_code=$?
fi
set -e

file_size=$(wc -c < "$log_file" | tr -d ' ')
echo "xcodebuild output saved to: $log_file"
echo "xcodebuild output size: $file_size bytes"
if [ "$use_xcsift" -eq 1 ]; then
  echo "Output formatter: xcsift $(xcsift --version)"
else
  echo "Output formatter: none (install xcsift for structured diagnostics)"
fi

if [ $exit_code -eq 0 ]; then
  echo "Status: SUCCESS"
else
  echo "Status: FAILED (exit code: $exit_code)"
  if [ "$use_xcsift" -ne 1 ]; then
    echo "Last 40 log lines:"
    tail -n 40 "$log_file" | sed 's/^/  /'
  fi
fi

echo "Tip: use \`tail -n 40 $log_file\` or \`rg --context 5 'error' $log_file\` for details."

exit $exit_code
