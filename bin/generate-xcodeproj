#!/usr/bin/env ruby
# frozen_string_literal: true

require 'fileutils'
require 'pathname'
require 'xcodeproj'

root = Pathname(__dir__).join('..').expand_path
project_path = root.join('Poof.xcodeproj')

FileUtils.rm_rf(project_path)
project = Xcodeproj::Project.new(project_path.to_s)
project.root_object.compatibility_version = Xcodeproj::Constants::COMPATIBILITY_VERSION_BY_OBJECT_VERSION[
  Xcodeproj::Constants::LAST_KNOWN_OBJECT_VERSION
]
project.root_object.attributes['LastUpgradeCheck'] = '2600'

app_group = project.main_group.new_group('Poof', 'Sources/Poof')
resources_group = app_group.new_group('Resources', 'Resources')

info_plist_ref = app_group.new_file('Info.plist')
resource_refs = [
  resources_group.new_file('Assets.xcassets'),
  resources_group.new_file('status-bar-icon.pdf'),
]

swift_refs = Dir.glob(root.join('Sources/Poof/*.swift').to_s).sort.map do |path|
  app_group.new_file(File.basename(path))
end

target = project.new_target(:application, 'Poof', :osx, '14.0')

target.add_file_references(swift_refs)
target.add_resources(resource_refs)

tomlkit_package = project.new(Xcodeproj::Project::Object::XCRemoteSwiftPackageReference)
tomlkit_package.repositoryURL = 'https://github.com/LebJe/TOMLKit'
tomlkit_package.requirement = {
  'kind' => 'upToNextMajorVersion',
  'minimumVersion' => '0.6.0',
}
project.root_object.package_references << tomlkit_package

tomlkit_product = project.new(Xcodeproj::Project::Object::XCSwiftPackageProductDependency)
tomlkit_product.package = tomlkit_package
tomlkit_product.product_name = 'TOMLKit'
target.package_product_dependencies << tomlkit_product

package_link = project.new(Xcodeproj::Project::Object::PBXBuildFile)
package_link.product_ref = tomlkit_product
target.frameworks_build_phase.files << package_link

base_build_settings = {
  'PRODUCT_BUNDLE_IDENTIFIER' => 'com.brnbw.Poof',
  'PRODUCT_NAME' => '$(TARGET_NAME)',
  'INFOPLIST_FILE' => 'Sources/Poof/Info.plist',
  'GENERATE_INFOPLIST_FILE' => 'NO',
  'MACOSX_DEPLOYMENT_TARGET' => '14.0',
  'SWIFT_VERSION' => '6.0',
  'MARKETING_VERSION' => '0.1.0',
  'CURRENT_PROJECT_VERSION' => '1',
  'ASSETCATALOG_COMPILER_APPICON_NAME' => 'AppIcon',
  'CODE_SIGN_STYLE' => 'Automatic',
}

target.build_configurations.each do |config|
  config.build_settings.merge!(base_build_settings)
  config.build_settings.delete('ASSETCATALOG_COMPILER_GLOBAL_ACCENT_COLOR_NAME')
end

project.build_configurations.each do |config|
  config.build_settings['MACOSX_DEPLOYMENT_TARGET'] = '14.0'
end

project.sort
project.save
puts "Generated #{project_path}"
